{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pes",
  "scopeName": "source.pes",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#type-literal" },
    { "include": "#map-literal-empty" },
    { "include": "#typed-collection-prefix" },
    { "include": "#array-literal" },
    { "include": "#collection-braced-literal" },
    { "include": "#number" },
    { "include": "#constant" },
    { "include": "#collection-type" },
    { "include": "#task-type" },
    { "include": "#type-name" },
    { "include": "#annotation" },
    { "include": "#keyword-extension" },
    { "include": "#this-parameter" },
    { "include": "#keyword-await" },
    { "include": "#keyword" },
    { "include": "#operator" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.pes",
          "match": "//.*$"
        },
        {
          "name": "comment.block.pes",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.pes",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-escape" },
            { "include": "#string-interpolation" }
          ]
        }
      ]
    },
    "string-escape": {
      "patterns": [
        {
          "name": "constant.character.escape.pes",
          "match": "\\\\."
        }
      ]
    },
    "string-interpolation": {
      "patterns": [
        { "include": "#string-interpolation-dollar-brace" },
        { "include": "#string-interpolation-percent-brace" },
        { "include": "#string-interpolation-percent-paren" },
        { "include": "#string-interpolation-percent-simple" },
        { "include": "#string-interpolation-dollar-simple" }
      ]
    },
    "string-interpolation-dollar-brace": {
      "name": "meta.template.expression",
      "begin": "(?<![\\\\])\\$\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.template-expression.begin" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.template-expression.end" }
      },
      "patterns": [
        {
          "begin": "\\|",
          "end": "(?=\\})",
          "beginCaptures": {
            "0": { "name": "punctuation.separator.format" }
          },
          "patterns": [
            {
              "match": "[^}]+",
              "name": "constant.other.format-specifier"
            }
          ]
        },
        {
          "begin": "(?<=\\{)",
          "end": "(?=\\||\\})",
          "contentName": "meta.embedded.expression.pes",
          "patterns": [
            { "include": "#source-inline" }
          ]
        }
      ]
    },
    "string-interpolation-percent-brace": {
      "name": "meta.template.expression",
      "begin": "(?<![\\\\])%\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.template-expression.begin" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.template-expression.end" }
      },
      "contentName": "meta.embedded.expression.pes",
      "patterns": [
        { "include": "#source-inline" }
      ]
    },
    "string-interpolation-percent-paren": {
      "name": "meta.template.expression",
      "begin": "(?<![\\\\])%\\(",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.template-expression.begin" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.definition.template-expression.end" }
      },
      "contentName": "meta.embedded.expression.pes",
      "patterns": [
        { "include": "#source-inline" }
      ]
    },
    "string-interpolation-percent-simple": {
      "match": "(?<![\\\\])(%)([A-Za-z袗-携邪-褟衼褢_][A-Za-z袗-携邪-褟衼褢0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.definition.template-expression.begin" },
        "2": { "name": "variable.other.readwrite" }
      }
    },
    "string-interpolation-dollar-simple": {
      "match": "(?<![\\\\])(\\$)([A-Za-z袗-携邪-褟衼褢_][A-Za-z袗-携邪-褟衼褢0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.definition.template-expression.begin" },
        "2": { "name": "variable.other.readwrite" }
      }
    },
    "source-inline": {
      "patterns": [
        { "include": "#number" },
        { "include": "#constant" },
        { "include": "#task-type" },
        { "include": "#collection-type" },
        { "include": "#type-name" },
        { "include": "#keyword-await" },
        { "include": "#keyword" },
        { "include": "#operator" },
        {
          "match": "[A-Za-z袗-携邪-褟衼褢_][A-Za-z袗-携邪-褟衼褢0-9_]*",
          "name": "variable.other.readwrite"
        }
      ]
    },
    "type-literal": {
      "patterns": [
        {
          "name": "constant.other.literal.pes",
          "match": "(?<![A-Za-z袗-携邪-褟衼褢0-9_])(?:袦芯屑械薪褌|Moment|袛邪褌邪|Date|袙褉械屑褟|Time|袛邪褌邪袙褉械屑褟|DateTime|袘邪泄褌褘|Bytes|校褍懈写|Uuid|孝懈锌|Type|效邪褋芯胁芯泄袩芯褟褋|效邪褋芯胁邪褟袟芯薪邪|TimeZone)\\{[^{}]*\\}"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.pes",
          "match": "(?<![A-Za-z袗-携邪-褟衼褢0-9_.])(?:\\d+(?:\\.\\d+)?(?:屑褋|屑懈薪|写薪|褋|褔)|0[xX][0-9a-fA-F]+|0[bB][01]+|\\d+\\.\\d+|\\d+)(?![A-Za-z袗-携邪-褟衼褢0-9_])"
        }
      ]
    },
    "constant": {
      "patterns": [
        {
          "name": "constant.language.pes",
          "match": "(?<![A-Za-z袗-携邪-褟衼褢0-9_])(?:袠褋褌懈薪邪|True|袥芯卸褜|False|袧械芯锌褉械写械谢械薪芯|Undefined)(?![A-Za-z袗-携邪-褟衼褢0-9_])"
        }
      ]
    },
    "type-name": {
      "patterns": [
        {
          "name": "support.type.pes",
          "match": "(?<![A-Za-z袗-携邪-褟衼褢0-9_])(?:效懈褋谢芯|Number|袘褍谢械胁芯|Boolean|小褌褉芯泻邪|String|袛邪褌邪|Date|袙褉械屑褟|Time|袛邪褌邪袙褉械屑褟|DateTime|袛谢懈褌械谢褜薪芯褋褌褜|Duration|袦芯屑械薪褌|Moment|袨斜褗械泻褌|Object|袘邪泄褌褘|Bytes|袠褋泻谢褞褔械薪懈械|Exception|效邪褋芯胁芯泄袩芯褟褋|效邪褋芯胁邪褟袟芯薪邪|TimeZone|袟邪写邪褔邪|Task|袦邪褋褋懈胁|Array|效懈褌邪械屑褘泄袦邪褋褋懈胁|袦薪芯卸械褋褌胁芯|Set|效懈褌邪械屑芯械袦薪芯卸械褋褌胁芯|小芯芯褌胁械褌褋褌胁懈械|Map|效懈褌邪械屑芯械小芯芯褌胁械褌褋褌胁懈械|袣谢褞褔袠袟薪邪褔械薪懈械|KeyValue)(?![A-Za-z袗-携邪-褟衼褢0-9_])"
        }
      ]
    },
    "type-in-params": {
      "patterns": [
        { "include": "#type-name" },
        {
          "match": ",",
          "name": "punctuation.separator.comma.pes"
        }
      ]
    },
    "collection-type": {
      "patterns": [
        {
          "name": "meta.type.generic.collection.pes",
          "begin": "(?<![A-Za-z袗-携邪-褟衼褢0-9_])(袦邪褋褋懈胁|Array|效懈褌邪械屑褘泄袦邪褋褋懈胁|袦薪芯卸械褋褌胁芯|Set|效懈褌邪械屑芯械袦薪芯卸械褋褌胁芯|小芯芯褌胁械褌褋褌胁懈械|Map|效懈褌邪械屑芯械小芯芯褌胁械褌褋褌胁懈械|袣谢褞褔袠袟薪邪褔械薪懈械|KeyValue)(<)",
          "beginCaptures": {
            "1": { "name": "support.type.collection.pes" },
            "2": { "name": "punctuation.definition.typeparameters.begin.pes" }
          },
          "end": ">",
          "endCaptures": {
            "0": { "name": "punctuation.definition.typeparameters.end.pes" }
          },
          "patterns": [
            { "include": "#type-in-params" }
          ]
        }
      ]
    },
    "typed-collection-prefix": {
      "match": "(?<![A-Za-z袗-携邪-褟衼褢0-9_>])(<)([A-Za-z袗-携邪-褟衼褢_][A-Za-z袗-携邪-褟衼褢0-9_,\\s]*)(>)(?=[\\[{])",
      "captures": {
        "1": { "name": "punctuation.definition.typeparameters.begin.pes" },
        "2": { "name": "support.type.pes" },
        "3": { "name": "punctuation.definition.typeparameters.end.pes" }
      }
    },
    "array-literal": {
      "match": "(\\[)([^\\[\\]]*(?:\"(?:[^\"\\\\]|\\\\.)*\"[^\\[\\]]*)*)(\\])",
      "captures": {
        "1": { "name": "punctuation.definition.array.begin.pes" },
        "2": { "name": "meta.collection.literal.content.pes" },
        "3": { "name": "punctuation.definition.array.end.pes" }
      }
    },
    "map-literal-empty": {
      "name": "meta.map.literal.pes",
      "match": "(?<![A-Za-z袗-携邪-褟衼褢0-9_])(\\{)(:)(\\})",
      "captures": {
        "1": { "name": "punctuation.definition.map.begin.pes" },
        "2": { "name": "punctuation.definition.map.empty.pes" },
        "3": { "name": "punctuation.definition.map.end.pes" }
      }
    },
    "collection-braced-literal": {
      "match": "(?<![A-Za-z袗-携邪-褟衼褢0-9_])(\\{)([^\\{\\}]*(?:\"(?:[^\"\\\\]|\\\\.)*\"[^\\{\\}]*)*)(\\})",
      "captures": {
        "1": { "name": "punctuation.definition.braces.begin.pes" },
        "2": { "name": "meta.collection.literal.content.pes" },
        "3": { "name": "punctuation.definition.braces.end.pes" }
      }
    },
    "map-literal-markers": {
      "patterns": [
        {
          "match": "=>",
          "name": "punctuation.separator.key-value.pes"
        },
        {
          "match": "(?<=[A-Za-z袗-携邪-褟衼褢0-9_\"\\])\\s*(:)\\s*(?=[\"A-Za-z袗-携邪-褟衼褢0-9_\\[{])",
          "captures": {
            "1": { "name": "punctuation.separator.key-value.pes" }
          }
        }
      ]
    },
    "collection-literal-inner": {
      "patterns": [
        { "include": "#map-literal-markers" },
        { "include": "#number" },
        { "include": "#constant" },
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.pes",
          "patterns": [
            { "include": "#string-escape" }
          ]
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.pes"
        }
      ]
    },
    "task-type": {
      "patterns": [
        {
          "name": "meta.type.generic.pes",
          "begin": "(?<![A-Za-z袗-携邪-褟衼褢0-9_])(袟邪写邪褔邪|Task)(<)",
          "beginCaptures": {
            "1": { "name": "support.type.pes" },
            "2": { "name": "punctuation.definition.typeparameters.begin.pes" }
          },
          "end": ">",
          "endCaptures": {
            "0": { "name": "punctuation.definition.typeparameters.end.pes" }
          },
          "patterns": [
            { "include": "#type-name" },
            { "include": "#task-type" }
          ]
        }
      ]
    },
    "keyword-extension": {
      "patterns": [
        {
          "name": "storage.modifier.extension.pes",
          "match": "(?<![A-Za-z袗-携邪-褟衼褢0-9_])(?:褉邪褋褕懈褉械薪懈械|extension)(?![A-Za-z袗-携邪-褟衼褢0-9_])"
        }
      ]
    },
    "this-parameter": {
      "patterns": [
        {
          "match": "(?<![A-Za-z袗-携邪-褟衼褢0-9_])(褝褌芯褌|this)\\s+([A-Za-z袗-携邪-褟衼褢_][A-Za-z袗-携邪-褟衼褢0-9_]*)\\s*:",
          "captures": {
            "1": { "name": "keyword.other.this" },
            "2": { "name": "variable.parameter" }
          }
        }
      ]
    },
    "keyword-await": {
      "patterns": [
        {
          "name": "keyword.control.await.pes",
          "match": "(?<![A-Za-z袗-携邪-褟衼褢0-9_])(?:卸写邪褌褜|await)(?![A-Za-z袗-携邪-褟衼褢0-9_])"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.pes",
          "match": "(?<![A-Za-z袗-携邪-褟衼褢0-9_])(?:懈薪邪褔械\\s+械褋谢懈|else\\s+if|constructor|泻芯薪褋褌褉褍泻褌芯褉|enumeration|锌械褉械褔懈褋谢械薪懈械|exception|懈褋泻谢褞褔械薪懈械|structure|褋褌褉褍泻褌褍褉邪|abstract|邪斜褋褌褉邪泻褌薪褘泄|async|邪褋懈薪褏|static|褋褌邪褌懈褔械褋泻懈泄|continue|锌褉芯写芯谢卸懈褌褜|褍屑芯谢褔邪薪懈械|default|finally|胁泻芯薪褑械|import|懈屑锌芯褉褌|export|褝泻褋锌芯褉褌|method|屑械褌芯写|return|胁芯蟹胁褉邪褌|throw|胁褘斜褉芯褋懈褌褜|break|锌褉械褉胁邪褌褜|while|锌芯泻邪|catch|锌芯泄屑邪褌褜|else|懈薪邪褔械|when|泻芯谐写邪|胁褘斜芯褉|case|try|锌芯锌褘褌泻邪|class|泻谢邪褋褋|contract|泻芯薪褌褉邪泻褌|for|写谢褟|loop|褑懈泻谢|step|褕邪谐|down|胁薪懈蟹|scope|芯斜谢邪褋褌褜|const|泻芯薪褋褌|void|薪懈褔褌芯|unknown|薪械懈蟹胁械褋褌薪芯|any|谢褞斜芯泄|this|褝褌芯褌|base|斜邪蟹芯胁褘泄|new|薪芯胁褘泄|use|懈褋锌|var|锌械褉|val|蟹薪褔|oblig|芯斜蟹|if|械褋谢懈|not|薪械|and|懈|or|懈谢懈|as|泻邪泻|is|褝褌芯|in|懈蟹|to|锌芯)(?![A-Za-z袗-携邪-褟衼褢0-9_])"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.pes",
          "match": "->|=>|\\*\\*|\\?\\?|\\?\\.|::|==|!=|<=|>=|\\+=|-=|\\*=|/=|%=|[+\\-*/%=<>?:]"
        }
      ]
    },
    "annotation": {
      "patterns": [
        { "include": "#annotation-with-args" },
        { "include": "#annotation-visibility" },
        { "include": "#annotation-known" },
        { "include": "#annotation-generic" }
      ]
    },
    "annotation-with-args": {
      "name": "meta.annotation.pes",
      "begin": "(@)([A-Za-z袗-携邪-褟衼褢_][A-Za-z袗-携邪-褟衼褢0-9_]*)\\s*(\\()",
      "beginCaptures": {
        "1": { "name": "punctuation.decorator.pes" },
        "2": { "name": "entity.name.tag.annotation.pes" },
        "3": { "name": "punctuation.section.begin.pes" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.end.pes" }
      },
      "patterns": [
        { "include": "#annotation-body" }
      ]
    },
    "annotation-body": {
      "patterns": [
        { "include": "#annotation" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#constant" },
        {
          "match": "([A-Za-z袗-携邪-褟衼褢_][A-Za-z袗-携邪-褟衼褢0-9_]*)\\s*=",
          "captures": {
            "1": { "name": "variable.parameter.pes" }
          }
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.pes"
        }
      ]
    },
    "annotation-visibility": {
      "name": "meta.annotation.visibility.pes",
      "match": "(@)(袥芯泻邪谢褜薪芯|袙袩芯写褋懈褋褌械屑械|袙袩褉芯械泻褌械|袙孝懈锌械|袚谢芯斜邪谢褜薪芯)(?![A-Za-z袗-携邪-褟衼褢0-9_])",
      "captures": {
        "1": { "name": "punctuation.decorator.pes" },
        "2": { "name": "storage.modifier.pes" }
      }
    },
    "annotation-known": {
      "name": "meta.annotation.known.pes",
      "match": "(@)(袩械褉械芯锌褉械写械谢械薪懈械|袪械邪谢懈蟹邪褑懈褟|袠屑械薪芯胁邪薪薪褘械袩邪褉邪屑械褌褉褘|校褋褌邪褉械谢芯|袣芯薪褌械泻褋褌薪褘泄|袨斜褉邪斜芯褌褔懈泻|袩芯写锌懈褋泻邪|袛芯褋褌褍锌薪芯小袣谢懈械薪褌邪|袧邪袣谢懈械薪褌械|袧邪小械褉胁械褉械)(?![A-Za-z袗-携邪-褟衼褢0-9_])",
      "captures": {
        "1": { "name": "punctuation.decorator.pes" },
        "2": { "name": "keyword.other.annotation.pes" }
      }
    },
    "annotation-generic": {
      "name": "meta.annotation.pes",
      "match": "(@)([A-Za-z袗-携邪-褟衼褢_][A-Za-z袗-携邪-褟衼褢0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.decorator.pes" },
        "2": { "name": "entity.name.tag.annotation.pes" }
      }
    }
  },
  "injections": {
    "L:string.quoted.double.pes": {
      "patterns": [
        { "include": "#string-escape" },
        { "include": "#string-interpolation" }
      ]
    },
    "L:meta.collection.literal.content.pes": {
      "patterns": [
        { "include": "#collection-literal-inner" }
      ]
    }
  }
}
